  "keyFeatures": [
    "Recursive Grid Mode - Coordinate-based screen subdivision",
    "Grid Mode - Quick coarse navigation",
    "Hints Mode - Accessibility-driven clickable labels",
    "Vim-Style Scrolling - Familiar j/k, gg/G navigation",
    "Direct Mouse Actions - Click, right-click, double-click, drag & drop",
    "Per-App Exclusions - Disable Neru in specific applications",
    "CLI & IPC - Full programmatic control and automation",
    "TOML Configuration - Version-controllable, shareable config",
    "Screen Sharing Mode - Hide overlays during presentations",
    "Service Management - Auto-start with launchd integration"
  ],
  "publicApiSurface": [
    "neru launch - Start the daemon",
    "neru hints - Activate hints mode",
    "neru grid - Activate grid mode",
    "neru recursive_grid - Activate recursive grid mode",
    "neru scroll - Activate scroll mode",
    "neru action left_click - Immediate left click",
    "neru action right_click - Immediate right click",
    "neru action double_click - Immediate double click",
    "neru action middle_click - Immediate middle click",
    "neru move_mouse - Move cursor to absolute position",
    "neru move_mouse_relative - Move cursor relatively",
    "neru start - Resume paused daemon",
    "neru stop - Pause daemon",
    "neru idle - Cancel active mode",
    "neru status - Check daemon status",
    "neru services install - Install auto-start service",
    "neru services uninstall - Remove auto-start service",
    "neru services status - Check service status",
    "neru config reload - Reload configuration",
    "neru toggle-screen-share - Toggle overlay visibility"
  ]
